{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/lectures/:path*", "destination": "/api/index.py" },
    { "source": "/subjects/:path*", "destination": "/api/index.py" },
    { "source": "/uploads/:path*",  "destination": "/api/index.py" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ]
}
